# Runtime and public service URLs
APP_NAME=RavenStore API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
API_PUBLIC_URL=
ADMIN_PUBLIC_URL=
STOREFRONT_PUBLIC_URL=
EXPOSE_API_DOCS=false
BACKEND_CORS_ORIGINS=
TRUSTED_PROXY_CIDRS=
SENSITIVE_SERVICE_ALLOWLIST=

# Supabase PostgreSQL and Storage
SUPABASE_PROJECT_REF=
SUPABASE_PROJECT_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATABASE_PASSWORD=
DATABASE_URL=
DATABASE_DIRECT_URL=
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
SUPABASE_PRODUCT_FILES_BUCKET=product-files
SUPABASE_PRODUCT_IMAGES_BUCKET=product-images
SUPABASE_BACKUPS_BUCKET=backups

# Redis, events and caching
REDIS_URL=
EVENT_STREAM_NAME=ravenstore:events:v1
EVENT_STREAM_MAX_LENGTH=100000
EVENT_WORKER_MAX_ATTEMPTS=12
EVENT_OUTBOX_RETENTION_DAYS=30
EVENT_SSE_HEARTBEAT_SECONDS=15
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_PREFIX=ravenstore:cache:v1

# Authentication and encryption
JWT_SECRET_KEY=
JWT_REFRESH_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ISSUER=ravenstore-api
JWT_AUDIENCE=ravenstore-clients
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
ENCRYPTION_KEY=
API_KEY_PEPPER=
LOGIN_MAX_ATTEMPTS=8
LOGIN_ATTEMPT_WINDOW_SECONDS=900
ACCOUNT_LOCKOUT_SECONDS=1800

# Payment switches
PAYMENT_TRC20_ENABLED=true
PAYMENT_BEP20_ENABLED=true
PAYMENT_BINANCE_ENABLED=false

# USDT TRC20
PAYMENT_USDT_TRC20_ADDRESS=
PAYMENT_USDT_TRC20_CONTRACT_ADDRESS=
PAYMENT_TRC20_CONFIRMATIONS=20
PAYMENT_TRC20_DECIMALS=6
TRON_GRID_API_KEY=

# USDT BEP20
PAYMENT_USDT_BEP20_ADDRESS=
PAYMENT_USDT_BEP20_CONTRACT_ADDRESS=
PAYMENT_BEP20_CONFIRMATIONS=15
PAYMENT_BEP20_DECIMALS=18
BSC_SCAN_API_KEY=

# Binance Pay
BINANCE_UID=
BINANCE_MERCHANT_ID=
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_WEBHOOK_PUBLIC_KEY=
BINANCE_PAY_BASE_URL=https://bpay.binanceapi.com

# Payment and fulfillment automation
PAYMENT_EXPIRY_MINUTES=45
PAYMENT_VERIFICATION_MAX_ATTEMPTS=12
PAYMENT_MANUAL_REVIEW_AMOUNT=1000
PAYMENT_FRAUD_SCORE_THRESHOLD=70
INVENTORY_RESERVATION_MINUTES=60
DELIVERY_MAX_ATTEMPTS=8

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_ADMIN_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_SERVICE_API_KEY=
INITIAL_OWNER_EMAIL=
INITIAL_OWNER_PASSWORD=

# Security and rate limits
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
METRICS_BEARER_TOKEN=

# Uploads and antivirus
UPLOADS_ENABLED=true
UPLOAD_QUARANTINE_DIR=./uploads/quarantine
UPLOAD_MAX_BYTES=26214400
UPLOAD_ALLOWED_TYPES=application/pdf,application/zip,image/jpeg,image/png,image/webp
UPLOAD_REQUIRE_ANTIVIRUS=true
CLAMAV_HOST=
CLAMAV_PORT=3310

# Backups
BACKUP_DIR=./backups
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_HOURS=24
BACKUP_ENCRYPTION_KEY=

# Resilience and observability
WORKER_HEARTBEAT_TTL_SECONDS=45
EXTERNAL_HTTP_TIMEOUT_SECONDS=20
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=30
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ravenstore-api
LOG_LEVEL=INFO
